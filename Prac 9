<html>

<head>
<title>MAHADBT Scholarship Form</title>

<style>
body {
    background-color: pink;
    font-family: Comic Sans;
}

svg {
    width: 90px;
    height: 90px;
    display: block;
    margin-bottom: 12px;
}
</style>

</head>

<body>

<h1 align="center">MAHADBT Scholarship Form</h1>

<form>

<fieldset>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
<path d="M160 64C124.7 64 96 92.7 96 128L96 512C96 547.3 124.7 576 160 576L448 576C483.3 576 512 547.3 512 512L512 128C512 92.7 483.3 64 448 64L160 64zM272 352L336 352C380.2 352 416 387.8 416 432C416 440.8 408.8 448 400 448L208 448C199.2 448 192 440.8 192 432C192 387.8 227.8 352 272 352zM248 256C248 225.1 273.1 200 304 200C334.9 200 360 225.1 360 256C360 286.9 334.9 312 304 312C273.1 312 248 286.9 248 256z"/>
</svg>
<legend>Applicant's Information</legend>

<label>Applicant Name</label>
<input type="text" placeholder="Enter applicant name"><br><br>

<label>Mother's Name</label>
<input type="text" placeholder="Enter mother's name"><br><br>

<label>Email</label>
<input type="email" placeholder="Enter email id"><br><br>

<label>Mobile Number</label>
<input type="tel" placeholder="Enter mobile number"><br><br>

<label>Date of Birth</label>
<input type="date">

</fieldset>

<br>

<fieldset>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
<path d="M320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320C64 178.6 178.6 64 320 64zM296 184L296 320C296 328 300 335.5 306.7 340L402.7 404C413.7 411.4 428.6 408.4 436 397.3C443.4 386.2 440.4 371.4 429.3 364L344 307.2L344 184C344 170.7 333.3 160 320 160C306.7 160 296 170.7 296 184z"/>
</svg>
<legend>Gender</legend>

<label><input type="radio" name="gender"> Male</label><br>
<label><input type="radio" name="gender"> Female</label><br>
<label><input type="radio" name="gender"> Other</label>

</fieldset>

<br>

<fieldset>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
<path d="M320 205.3L320 514.6L320.5 514.4C375.1 491.7 433.7 480 492.8 480L512 480L512 160L492.8 160C450.6 160 408.7 168.4 369.7 184.6C352.9 191.6 336.3 198.5 320 205.3z"/>
</svg> 
<legend>Address Details</legend>

<label>Address</label>
<input type="text" placeholder="Enter address"><br><br>

<label>District</label>
<select>
<option>Select District</option>
<option>Gadchiroli</option>
<option>Sangli</option>
<option>Nanded</option>
<option>Nashik</option>
<option>Chandrapur</option>
</select>

</fieldset>

<br>

<fieldset>
<legend>Education Qualification</legend>

<label>College Name</label>
<input type="text" placeholder="Enter college name"><br><br>

<label>Course</label>
<select>
<option>Select Course</option>
<option>MBBS</option>
<option>BAMS</option>
<option>BDS</option>
<option>BHMS</option>
<option>Physiotherapy</option>
</select>

<br><br>

<label>Percentage in HSC Exam</label>
<input type="number" placeholder="Enter percentage">

</fieldset>

<br>

<fieldset>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
<path d="M341.8 72.6C329.5 61.2 310.5 61.2 298.3 72.6L74.3 280.6C64.7 289.6 61.5 303.5 66.3 315.7C71.1 327.9 82.8 336 96 336L112 336L112 512C112 547.3 140.7 576 176 576L464 576C499.3 576 528 547.3 528 512L528 336L544 336C557.2 336 569 327.9 573.8 315.7C578.6 303.5 575.4 289.5 565.8 280.6L341.8 72.6z"/>
</svg>
<legend>Scholarship Details</legend>

<label>Scholarship Scheme</label>
<select>
<option>Select Scheme</option>
<option>AICTE Pragati Scholarship for Girl</option>
<option>AICTE Saksham Scholarship Scheme</option>
<option>Tata Trusts Scholarship</option>
</select>

<br><br>

<label>Documents Submitted</label><br>

<input type="checkbox"> Aadhaar Card<br>
<input type="checkbox"> Income Certificate<br>
<input type="checkbox"> Caste Certificate<br>
<input type="checkbox"> 12th Marksheet

</fieldset>

<br>

<input type="submit" value="Submit">
<input type="reset" value="Reset Form">

</form>

</body>
</html>
